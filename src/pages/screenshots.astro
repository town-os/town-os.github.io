---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;

const screenshots = [
  { file: 'create-account.png', title: 'Create Account', desc: 'Set up your first administrator account when you visit Town OS for the first time.' },
  { file: 'dashboard.png', title: 'Dashboard', desc: 'System overview with at-a-glance cards for filesystems, accounts, services, packages, repositories, and audit status.' },
  { file: 'packages.png', title: 'Packages', desc: 'Browse, search, and manage packages available from your configured repositories.' },
  { file: 'installation.png', title: 'Installation', desc: 'Interactive prompts guide you through configuring each package before installation.' },
  { file: 'install-details.png', title: 'Install Details', desc: 'Review installed package configuration, setup responses, and connection details.' },
  { file: 'services.png', title: 'Services', desc: 'View and manage running services with status indicators and quick actions.' },
  { file: 'logs.png', title: 'Logs', desc: 'Live journal output with filtering, following, and collapsible entries for running services.' },
  { file: 'storage.png', title: 'Storage', desc: 'Manage btrfs subvolumes, quotas, and installed package volumes.' },
  { file: 'monitoring.png', title: 'Monitoring', desc: 'Powered by Grafana and Prometheus, dashboards are automatically set up and fully customizable.' },
  { file: 'settings.png', title: 'Settings', desc: 'Configure system-wide settings and preferences for your Town OS installation.' },
  { file: 'auditlog.png', title: 'Audit Log', desc: 'Track every API action — installs, logins, account changes — with timestamps, user attribution, request payloads, and generated errors.' },
];
---

<BaseLayout title="Screenshots — Town OS">
  <section class="section">
    <div class="container">
      <h1>Screenshots</h1>
      <p class="page-lead">
        See Town OS in action. These screenshots show the current development build —
        a fully working dashboard for managing packages, services, storage, and users.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="gallery">
        {screenshots.map((shot) => (
          <div class="gallery-item">
            <a href={`${base}images/screenshots/${shot.file}`} target="_blank" rel="noopener" class="gallery-link">
              <img
                src={`${base}images/screenshots/${shot.file}`}
                alt={shot.title}
                loading="lazy"
                decoding="async"
              />
            </a>
            <div class="gallery-caption">
              <h3>{shot.title}</h3>
              <p>{shot.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-lead {
    font-size: 1.15rem;
    color: var(--color-text-muted);
    max-width: 720px;
    margin-top: 1rem;
  }

  .gallery {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }

  .gallery-item {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    overflow: hidden;
    transition: border-color 0.2s, transform 0.2s;
  }

  .gallery-item:hover {
    border-color: var(--color-primary-dim);
    transform: translateY(-2px);
  }

  .gallery-link {
    display: block;
    overflow: hidden;
    background: #111;
  }

  .gallery-link img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.3s;
  }

  .gallery-item:hover .gallery-link img {
    transform: scale(1.02);
  }

  .gallery-caption {
    padding: 1rem 1.25rem;
  }

  .gallery-caption h3 {
    font-size: 1.05rem;
    margin-bottom: 0.3rem;
  }

  .gallery-caption p {
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }

  @media (max-width: 768px) {
    .gallery {
      grid-template-columns: 1fr;
    }
  }
</style>
