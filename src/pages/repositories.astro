---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Repositories — Town OS">
  <section class="section">
    <div class="container repos-container">
      <h1>Repositories</h1>
      <p class="page-lead">
        All Town OS source code lives on <a href="https://gitea.com/town-os" target="_blank" rel="noopener">Gitea</a>. GitHub mirrors exist at <a href="https://github.com/town-os" target="_blank" rel="noopener">github.com/town-os</a> but are often out of date.
      </p>

      <div class="repo-links">
        <a href="https://gitea.com/town-os/town-os" target="_blank" rel="noopener" class="repo-card repo-card--highlight">
          <div class="card-icon">
            <svg viewBox="0 0 24 24" width="40" height="40" fill="currentColor">
              <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
            </svg>
          </div>
          <div class="card-content">
            <h2>Town OS</h2>
            <p>The core product. Follow the <code>stable</code> branch for release-level changes. File issues if you see anything.</p>
          </div>
          <span class="card-arrow">&rarr;</span>
        </a>

        <a href="https://gitea.com/town-os/rolodex" target="_blank" rel="noopener" class="repo-card">
          <div class="card-icon">
            <svg viewBox="0 0 24 24" width="40" height="40" fill="currentColor">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>
            </svg>
          </div>
          <div class="card-content">
            <h2>Rolodex</h2>
            <p>Standards-compliant DNS server with full DNSSEC validation and DANE support. Enables ad blocking, malware blocking, and personal domains for your network. Designed to double as a personal trust root. DHCP also planned.</p>
          </div>
          <span class="card-arrow">&rarr;</span>
        </a>

        <a href="https://gitea.com/town-os/install" target="_blank" rel="noopener" class="repo-card">
          <div class="card-icon">
            <svg viewBox="0 0 24 24" width="40" height="40" fill="currentColor">
              <path d="M18 8h-2V6c0-2.21-1.79-4-4-4S8 3.79 8 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zM12 17c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3-9H9V6c0-1.66 1.34-3 3-3s3 1.34 3 3v2z"/>
            </svg>
          </div>
          <div class="card-content">
            <h2>Install</h2>
            <p>Very experimental — the USB drive installer. This is currently the least safe way to try Town OS, so prefer working from the development repository instead. Still very much in the works — keep your eye on it.</p>
          </div>
          <span class="card-arrow">&rarr;</span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .repos-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .page-lead {
    font-size: 1.15rem;
    color: var(--color-text-muted);
    max-width: 720px;
    margin-top: 1rem;
  }

  .page-lead a {
    color: var(--color-accent);
  }

  .repo-links {
    display: grid;
    gap: 1.5rem;
    margin-top: 2.5rem;
    max-width: 640px;
    width: 100%;
  }

  .repo-card {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 1.5rem;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    color: var(--color-text);
    text-decoration: none;
    cursor: pointer;
    transition: border-color 0.2s, transform 0.2s;
  }

  .repo-card--highlight {
    border-color: var(--color-accent);
    background: color-mix(in srgb, var(--color-accent) 6%, var(--color-bg-card));
  }

  .repo-card:hover {
    border-color: var(--color-primary-dim);
    transform: translateY(-2px);
  }

  .card-icon {
    flex-shrink: 0;
    color: var(--color-accent);
  }

  .card-content {
    flex: 1;
    text-align: left;
  }

  .card-content h2 {
    font-size: 1.15rem;
    margin-bottom: 0.25rem;
  }

  .card-content p {
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }

  .card-content code {
    background: var(--color-bg-elevated);
    padding: 0.1em 0.4em;
    border-radius: 4px;
    font-size: 0.85em;
  }

  .card-arrow {
    font-size: 1.5rem;
    color: var(--color-text-muted);
    transition: color 0.2s, transform 0.2s;
  }

  .repo-card:hover .card-arrow {
    color: var(--color-accent);
    transform: translateX(4px);
  }

  @media (max-width: 768px) {
    .repo-card {
      padding: 1.25rem;
    }
  }
</style>
