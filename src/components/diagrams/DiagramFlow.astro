---
interface Props {
  title?: string;
}
const { title } = Astro.props;
---
<div class="my-8">
  {title && <div class="text-town-muted text-sm font-semibold mb-3 tracking-wide uppercase">{title}</div>}
  <div class="flex flex-col md:flex-row items-stretch md:items-center gap-3 md:gap-4">
    <slot />
  </div>
</div>
