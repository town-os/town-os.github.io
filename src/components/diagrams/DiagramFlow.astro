---
interface Props {
  title?: string;
}
const { title } = Astro.props;
---
<div class="mt-12 mb-8 flex flex-col items-center">
  {title && <div class="text-town-muted text-sm font-semibold mb-3 tracking-wide uppercase">{title}</div>}
  <div class="flex flex-col items-center gap-3 w-full max-w-md">
    <slot />
  </div>
</div>
