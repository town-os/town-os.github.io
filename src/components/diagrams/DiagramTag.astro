---
interface Props {
  variant?: 'purple' | 'teal' | 'neutral';
}
const { variant = 'neutral' } = Astro.props;
const colors = {
  purple: 'bg-town-primary/20 text-town-primary-light border-town-primary/30',
  teal: 'bg-town-accent/10 text-town-accent border-town-accent/20',
  neutral: 'bg-town-bg/50 text-town-muted border-town-border',
};
---
<span class={`inline-block text-xs px-3 py-1 rounded-full border mt-2 mr-1 ${colors[variant]}`}><slot /></span>
